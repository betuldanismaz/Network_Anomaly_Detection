# ===========================================================================
# Ortam değişkenleri örneği — bu dosyayı `.env` olarak kopyalayıp düzenleyin.
# (Gerçek `.env` git'e gönderilmez; bkz. .gitignore)
# ===========================================================================

# --- Ağ / yakalama ---
NETWORK_INTERFACE=Wi-Fi
TARGET_IP=192.168.1.1

# --- Güvenlik duvarı / yanıt ---
# Asla engellenmeyecek IP'ler (virgülle ayrılır)
WHITELIST_IPS=192.168.1.1,127.0.0.1,0.0.0.0,localhost
# Otomatik engelin kaç saniye sonra kalkacağı (TTL)
BLOCK_TTL_SECONDS=3600

# --- Eskalasyon eşikleri (kafka_consumer + pano; config.py okur) ---
# Aynı IP'den son kaç saniyelik pencerede tespitler sayılır
ESCALATION_WINDOW_SECONDS=60
# Bu sayıya ulaşınca ŞÜPHELİ işaretlenir
ESCALATION_SUSPICIOUS_THRESHOLD=2
# Bu sayıya ulaşınca otomatik ENGELLENİR
ESCALATION_BLOCK_THRESHOLD=4

# --- Pano ---
# Zaman-serisi gruplama frekansı (pandas freq, ör. 10s, 30s, 1min)
BUCKET_FREQUENCY=10s

# --- Kafka ---
KAFKA_GROUP_ID=nids-consumer-group-v2
KAFKA_AUTO_OFFSET_RESET=latest
